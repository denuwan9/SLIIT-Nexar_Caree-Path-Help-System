# ── Vercel Deployment Env Template ────────────────────────────────────
# Copy these to your Vercel Project Settings > Environment Variables

# ── Backend Configuration ──────────────────────────────────────────────
NODE_ENV=production
PORT=5000
FRONTEND_URL=https://your-vercel-domain.vercel.app

# ── MongoDB ───────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://denuwan:denuwan123456@cluster0.7ukdb.mongodb.net/SLIITNexara

# ── JWT Security ──────────────────────────────────────────────────────
JWT_SECRET=generate_a_long_random_string_for_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=generate_another_separate_random_string
JWT_REFRESH_EXPIRES_IN=30d

# ── Cloudinary (Image Storage) ────────────────────────────────────────
CLOUDINARY_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Groq AI (Intelligence) ────────────────────────────────────────────
GROQ_API_KEY=gsk_...

# ── Google Integration ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_secret
GOOGLE_REDIRECT_URI=https://your-vercel-domain.vercel.app

# ── Email Service (Gmail/SMTP) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# ── Frontend Configuration ─────────────────────────────────────────────
# Use these in your Vercel Project Settings as well
VITE_API_URL=https://your-vercel-domain.vercel.app/api/v1
